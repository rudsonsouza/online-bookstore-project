# Copy this file to .env and fill in the values before running docker-compose.
# .env is listed in .gitignore and must never be committed.

# PostgreSQL
POSTGRES_DB=bookstore
POSTGRES_USER=bookstore
POSTGRES_PASSWORD=change_me_in_production

# WildFly datasource (must match PostgreSQL values above)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bookstore
DB_USER=bookstore
DB_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Liquibase Maven plugin (used during local development: mvn liquibase:update)
DB_URL=jdbc:postgresql://localhost:5432/bookstore
